{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "kilo-agentmemory-bridge",
  "version": "0.2.1",
  "description": "Kilo/OpenCode plugin bridge for agentmemory.",
  "keywords": [
    "agentmemory",
    "kilo",
    "opencode",
    "plugin",
    "claude-code",
    "memory"
  ],
  "homepage": "https://github.com/piotrpaj/kilo-agentmemory-bridge#readme",
  "bugs": {
    "url": "https://github.com/piotrpaj/kilo-agentmemory-bridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piotrpaj/kilo-agentmemory-bridge.git"
  },
  "type": "module",
  "license": "MIT",
  "packageManager": "npm@11.13.0",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts",
      "config": {
        "url": {
          "type": "string",
          "description": "agentmemory server URL",
          "default": "http://localhost:3111",
          "env": "AGENTMEMORY_URL"
        },
        "secret": {
          "type": "string",
          "description": "Bearer token for agentmemory, when configured",
          "env": "AGENTMEMORY_SECRET"
        },
        "tokenBudget": {
          "type": "number",
          "description": "Token budget for recalled session context",
          "default": 2000,
          "env": "AGENTMEMORY_TOKEN_BUDGET"
        },
        "compactionBudget": {
          "type": "number",
          "description": "Token budget for recalled compaction context"
        },
        "timeoutMs": {
          "type": "number",
          "description": "Default agentmemory request timeout in milliseconds",
          "default": 3000
        },
        "shortTimeoutMs": {
          "type": "number",
          "description": "Timeout for best-effort observation requests in milliseconds",
          "default": 800
        },
        "injectTimeoutMs": {
          "type": "number",
          "description": "Timeout for context and enrichment requests in milliseconds",
          "default": 1500
        },
        "summarizeTimeoutMs": {
          "type": "number",
          "description": "Timeout for stop summarization requests in milliseconds",
          "default": 120000
        },
        "sessionEndTimeoutMs": {
          "type": "number",
          "description": "Timeout for terminal session end requests in milliseconds",
          "default": 30000
        },
        "consolidationTimeoutMs": {
          "type": "number",
          "description": "Timeout for optional consolidation requests in milliseconds",
          "default": 120000
        },
        "injectSessionContext": {
          "type": "boolean",
          "description": "Inject recalled session context into the system prompt",
          "default": true,
          "env": "AGENTMEMORY_INJECT_SESSION_CONTEXT"
        },
        "injectToolContext": {
          "type": "boolean",
          "description": "Fetch pre-tool enrichment context for file/search tools",
          "default": false,
          "env": "AGENTMEMORY_INJECT_CONTEXT"
        },
        "summarizeOnStop": {
          "type": "boolean",
          "description": "Call summarize when Kilo emits session.idle",
          "default": true,
          "env": "AGENTMEMORY_SUMMARIZE_ON_STOP"
        },
        "consolidationEnabled": {
          "type": "boolean",
          "description": "Run optional consolidation endpoints on terminal session end",
          "default": false,
          "env": "CONSOLIDATION_ENABLED"
        },
        "memoryBridgeSync": {
          "type": "boolean",
          "description": "Run optional Claude memory bridge sync during compaction and session end",
          "default": false,
          "env": "CLAUDE_MEMORY_BRIDGE"
        },
        "endSessionOnIdle": {
          "type": "boolean",
          "description": "Treat session.idle as terminal session end for legacy behavior",
          "default": false
        }
      }
    },
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "engines": {
    "node": ">=18",
    "opencode": "^1.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.15.0",
    "@types/node": "^24.12.2",
    "typescript": "^5.8.2"
  }
}
